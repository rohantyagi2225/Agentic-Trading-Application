# =============================================================================
# DATABASE & CACHE
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic
REDIS_URL=redis://localhost:6379/0
SUPABASE_DB_URL=
UPSTASH_REDIS_URL=

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_LOG_LEVEL=INFO

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
AUTH_TOKEN_SECRET=change-me-in-production-use-32-random-characters
AUTH_TOKEN_TTL_HOURS=12
JWT_ALGORITHM=HS256

# =============================================================================
# CORS & FRONTEND
# =============================================================================
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
APP_BASE_URL=http://localhost:3000

# =============================================================================
# MARKET DATA PROVIDERS (Priority Order)
# =============================================================================
HOT_SYMBOLS=AAPL,NVDA,MSFT,TSLA,AMZN,META,SPY,QQQ,BTC-USD,ETH-USD,^GSPC
HOT_TIMEFRAMES=15M,1H,1D,1W,1M
MARKET_WARM_INTERVAL_SECONDS=20
MARKET_PROVIDER_ORDER=yfinance,polygon,finnhub,twelvedata,alpaca
MARKET_PROVIDER_TIMEOUT_SECONDS=3.0
MARKET_PROVIDER_RETRY_COUNT=1
MARKET_PROVIDER_FAILURE_THRESHOLD=3
MARKET_PROVIDER_RESET_SECONDS=45
SLOW_REQUEST_THRESHOLD_MS=500

# API Keys (Optional - leave blank to use free providers)
POLYGON_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_FEED=iex

# =============================================================================
# RISK MANAGEMENT CONFIGURATION
# =============================================================================
RISK_MAX_POSITION_PCT=0.10
RISK_MAX_DRAWDOWN_PCT=0.15
RISK_STOP_LOSS_PCT=0.05
RISK_ENABLE_CIRCUIT_BREAKERS=true
RISK_MAX_DAILY_LOSS_PCT=0.05

# =============================================================================
# TRANSACTION COST MODEL
# =============================================================================
TRANSACTION_COMMISSION_PER_SHARE=0.005
TRANSACTION_MIN_COMMISSION=1.0
TRANSACTION_SLIPPAGE_BPS=1.0
TRANSACTION_MARKET_IMPACT_BPS=0.5

# =============================================================================
# DEPLOYMENT PLATFORMS
# =============================================================================
RAILWAY_PUBLIC_DOMAIN=
RENDER_EXTERNAL_URL=
DOCKER_REGISTRY=
DOCKER_IMAGE_NAME=agentic-trading-app

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# =============================================================================
# NEO4J GRAPH DATABASE (Optional)
# =============================================================================
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_DATABASE=neo4j

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_FORMAT=json
LOG_FILE=logs/app.log
LOG_RETENTION_DAYS=30
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# TRADING AGENT CONFIGURATION
# =============================================================================
AGENT_POOL_ENABLED=true
AGENT_MEMORY_ENABLED=true
AGENT_DECISION_LOGGING=true
AGENT_WALK_FORWARD_ENABLED=true
AGENT_MONTE_CARLO_SIMULATIONS=1000
